@page "/exchange-rates"

<div class="er-page">
    <div class="er-header">
        <div class="er-header-top">
            <div>
                <h3>Exchange Rates</h3>
                <p class="er-subtitle">Live foreign exchange rates</p>
            </div>
            <button class="er-refresh-btn" @onclick="RefreshRates" disabled="@isLoading">
                <span class="er-refresh-icon @(isLoading ? "er-spinning" : "")">&#8635;</span>
                @(isLoading ? "Refreshing..." : "Refresh")
            </button>
        </div>
    </div>

    @if (source != null)
    {
        <div class="er-meta-grid">
            <div class="er-meta-card">
                <span class="er-meta-label">Source Currency</span>
                <span class="er-meta-value">@source</span>
            </div>
            <div class="er-meta-card">
                <span class="er-meta-label">Last Updated</span>
                <span class="er-meta-value">@timestamp?.ToString("yyyy-MM-dd HH:mm:ss UTC")</span>
            </div>
            <div class="er-meta-card">
                <span class="er-meta-label">Terms</span>
                <a class="er-meta-link" href="@terms" target="_blank">View Terms</a>
            </div>
            <div class="er-meta-card">
                <span class="er-meta-label">Privacy</span>
                <a class="er-meta-link" href="@privacy" target="_blank">View Policy</a>
            </div>
        </div>
    }

    <div class="er-table-wrapper">
        <table class="table table-striped table-sm table-bordered er-table">
            <thead>
                <tr>
                    <th>Base Currency</th>
                    <th>Target Currency</th>
                    <th>Rate</th>
                </tr>
            </thead>
            <tbody>
                @if (exchangeRateDetailsList == null || !exchangeRateDetailsList.Any())
                {
                    <tr>
                        <td colspan="3" class="er-empty">No exchange rates available.</td>
                    </tr>
                }
                else
                {
                    @foreach (var rate in pagedList)
                    {
                        <ExchangeRateDetailsComponent BaseCurrency="@rate.BaseCurrency" TargetCurrency="@rate.TargetCurrency" Rate="@rate.Rate" />
                    }
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <nav class="er-pagination">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">&laquo;</button>
                </li>
                @for (int p = 1; p <= totalPages; p++)
                {
                    var pageNum = p;
                    <li class="page-item @(currentPage == pageNum ? "active" : "")">
                        <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">&raquo;</button>
                </li>
            </ul>
        </nav>
    }
</div>
